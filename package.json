{
  "name": "idle-sect-life",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "IdleSectLife — idle/incremental wuxia sect management game (vanilla TS + Vite)",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test:sim": "esbuild scripts/smoke.ts --bundle --platform=node --format=esm --outfile=scripts/.out.sim.mjs && node scripts/.out.sim.mjs",
    "test:ui": "esbuild scripts/render-smoke.ts --bundle --platform=node --format=esm --packages=external --outfile=scripts/.out.ui.mjs && node scripts/.out.ui.mjs",
    "test:ctrl": "esbuild scripts/controller-smoke.ts --bundle --platform=node --format=esm --packages=external --outfile=scripts/.out.ctrl.mjs && node scripts/.out.ctrl.mjs",
    "test": "npm run test:sim && npm run test:ui && npm run test:ctrl"
  },
  "devDependencies": {
    "jsdom": "^24.1.3",
    "typescript": "^5.5.4",
    "vite": "^5.4.10"
  },
  "dependencies": {
    "interactjs": "^1.10.27"
  }
}
