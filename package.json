{
  "name": "idle-sect-life",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Sect: Ascendant — idle/incremental wuxia sect management game (React + Vite)",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test:sim": "esbuild scripts/smoke.ts --bundle --platform=node --format=esm --outfile=scripts/.out.sim.mjs && node scripts/.out.sim.mjs",
    "test:ui": "esbuild scripts/render-smoke.tsx --bundle --platform=node --format=esm --jsx=automatic --packages=external --outfile=scripts/.out.ui.mjs && node scripts/.out.ui.mjs",
    "test:engine": "esbuild scripts/engine-smoke.ts --bundle --platform=node --format=esm --packages=external --outfile=scripts/.out.engine.mjs && node scripts/.out.engine.mjs",
    "test": "npm run test:sim && npm run test:ui && npm run test:engine"
  },
  "devDependencies": {
    "@types/react": "^18.3.29",
    "@types/react-dom": "^18.3.7",
    "@types/react-grid-layout": "^1.3.6",
    "@vitejs/plugin-react": "^4.7.0",
    "jsdom": "^24.1.3",
    "typescript": "^5.5.4",
    "vite": "^5.4.10"
  },
  "dependencies": {
    "motion": "^12.40.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-grid-layout": "^1.5.0",
    "zod": "^4.4.3"
  }
}
